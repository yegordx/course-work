{
  "openapi": "3.0.1",
  "info": {
    "title": "server",
    "version": "1.0"
  },
  "paths": {
    "/api/clients/register": {
      "post": {
        "tags": [
          "Clients"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/clients/login": {
      "post": {
        "tags": [
          "Clients"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/clients/plan": {
      "post": {
        "tags": [
          "Clients"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SelectPlanDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SelectPlanDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SelectPlanDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/clients/embedding-provider": {
      "post": {
        "tags": [
          "Clients"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetProviderDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SetProviderDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SetProviderDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/faq": {
      "post": {
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FaqUploadDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/FaqUploadDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/FaqUploadDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/apikey": {
      "get": {
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/clients/profile": {
      "get": {
        "tags": [
          "Clients"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/clients/logout": {
      "post": {
        "tags": [
          "Clients"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateClientDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "FaqUploadDto": {
        "type": "object",
        "properties": {
          "questions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SelectPlanDto": {
        "required": [
          "durationMonths"
        ],
        "type": "object",
        "properties": {
          "durationMonths": {
            "maximum": 12,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "SetProviderDto": {
        "required": [
          "providedKey",
          "providerName"
        ],
        "type": "object",
        "properties": {
          "providerName": {
            "minLength": 1,
            "pattern": "^(OpenAI|Cohere|HuggingFace)$",
            "type": "string"
          },
          "providedKey": {
            "minLength": 10,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}